<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>

<title>Plans Management</title>
</head>

<%- include("../partials/toast") %>

<body class="bg-slate-100">

<div class="flex min-h-screen">

<!-- SIDEBAR -->
<aside class="w-72 bg-slate-900 text-white p-6">

<h1 class="text-2xl font-bold mb-10">
⚡ AlgoMoney Admin
</h1>

<nav class="space-y-3">

<a href="/admin/dashboard" class="block hover:bg-slate-800 px-4 py-3 rounded-lg">
<i class="fa fa-chart-line mr-2"></i> Dashboard
</a>

<a href="/admin/plans" class="block bg-slate-800 px-4 py-3 rounded-lg">
<i class="fa fa-layer-group mr-2"></i> Plans
</a>

</nav>
</aside>

<!-- MAIN -->
<main class="flex-1 p-10">

<!-- HEADER -->
<div class="flex justify-between items-center mb-10">

<h2 class="text-3xl font-bold">
Plans Management
</h2>

<button onclick="document.getElementById('createModal').classList.remove('hidden')"
class="bg-slate-900 text-white px-5 py-2 rounded-lg">
+ Create Plan
</button>

</div>

<!-- TABLE -->
<div class="bg-white rounded-2xl shadow p-6">

<table class="w-full text-left">

<thead>
<tr class="border-b">
<th class="p-3">Title</th>
<th>Price</th>
<th>Status</th>
<th>Created</th>
<th>Action</th>
</tr>
</thead>

<tbody>

<% plans.forEach(plan => { %>

<tr class="border-b hover:bg-slate-50">

<td class="p-3 font-semibold uppercase">
<%= plan.title %>
</td>

<td>
₹ <%= plan.price %>
</td>

<td>
<span class="px-3 py-1 rounded-full text-sm
<%= plan.isActive ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600' %>">
<%= plan.isActive ? "Active" : "Inactive" %>
</span>
</td>

<td>
<%= new Date(plan.createdAt).toLocaleDateString() %>
</td>

<td class="space-x-3">

<a href="/admin/toggle-plan/<%= plan._id %>"
class="text-blue-600 font-semibold">
Toggle
</a>

<a href="/admin/update-plan/<%= plan._id %>"
class="text-blue-600 font-semibold">
Update
</a>

<form action="/admin/delete-plan/<%= plan._id %>?_method=DELETE"
method="POST"
class="inline"
onsubmit="return confirm('Are you sure?')">

<button type="submit" class="text-red-500 font-semibold">
Delete
</button>

</form>

</td>

</tr>

<% }) %>

</tbody>
</table>

</div>

</main>

</div>



<!-- ================= CREATE PLAN MODAL ================= -->

<div id="createModal"
class="fixed inset-0 bg-black/50 hidden overflow-y-auto flex items-start justify-center py-10">

<div class="bg-white w-[500px] rounded-2xl p-8 shadow-2xl">

<h3 class="text-2xl font-bold mb-6">Create Plan</h3>

<form action="/admin/create-plan" method="POST">

<div class="space-y-4">

<label class="block font-medium">Plan Type</label>
<select name="title"
class="w-full border p-3 rounded-lg"
required>
<option value="">Select Plan</option>
<option value="starter">Starter</option>
<option value="pro">Pro</option>
<option value="elite">Elite</option>
</select>

<label class="block font-medium">Price</label>
<input type="number"
name="price"
placeholder="Enter Plan Price"
class="w-full border p-3 rounded-lg"
required>

</div>

<div class="flex justify-end gap-4 mt-8">

<button type="button"
onclick="document.getElementById('createModal').classList.add('hidden')"
class="px-4 py-2 border rounded-lg">
Cancel
</button>

<button type="submit"
class="bg-slate-900 text-white px-6 py-2 rounded-lg">
Create Plan
</button>

</div>

</form>

</div>

</div>

</body>
</html>
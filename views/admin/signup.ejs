<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>
<style>
@keyframes float {
0% { transform: translateY(0px); }
50% { transform: translateY(-20px); }
100% { transform: translateY(0px); }
}

h1{
animation: float 8s ease-in-out infinite;
}
</style>


<title>Admin Signup | AlgoMoney</title>
</head>

<%- include("../partials/toast") %>

<body class="bg-slate-100 flex items-center justify-center min-h-screen relative overflow-hidden">


<!-- SOFT BACKGROUND WORD -->
<div class="absolute inset-0 flex items-center justify-center pointer-events-none">

<h1 class="text-[10vw] font-extrabold text-slate-200 tracking-widest select-none">
AlgoMoney
</h1>

</div>



<!-- CARD -->
<div class="relative z-10 bg-white w-full max-w-lg p-10 rounded-2xl shadow-lg border border-slate-200">

<!-- HEADER -->
<div class="text-center mb-8">
<h1 class="text-3xl font-bold text-slate-900">
⚡ AlgoMoney Admin
</h1>

<p class="text-slate-500 mt-2">
Create a secure administrator account
</p>
</div>



<!-- FORM -->
<form action="/admin/signup" method="POST" class="space-y-6">

<!-- NAME -->
<div>
<label class="text-sm font-semibold text-slate-600">
Full Name
</label>

<div class="relative mt-2">
<i class="fa fa-user absolute top-4 left-3 text-slate-400"></i>

<input
type="text"
name="name"
required
class="w-full pl-10 pr-4 py-3 rounded-xl bg-white border border-slate-300 focus:border-slate-900 focus:ring-1 focus:ring-slate-900 outline-none transition"
placeholder="John Admin"
/>
</div>
</div>


<!-- EMAIL -->
<div>
<label class="text-sm font-semibold text-slate-600">
Admin Email
</label>

<div class="relative mt-2">
<i class="fa fa-envelope absolute top-4 left-3 text-slate-400"></i>

<input
type="email"
name="email"
required
class="w-full pl-10 pr-4 py-3 rounded-xl bg-white border border-slate-300 focus:border-slate-900 focus:ring-1 focus:ring-slate-900 outline-none transition"
placeholder="admin@algomoney.com"
/>
</div>
</div>


<!-- PASSWORD -->
<div>
<label class="text-sm font-semibold text-slate-600">
Password
</label>

<div class="relative mt-2">
<i class="fa fa-lock absolute top-4 left-3 text-slate-400"></i>

<input
type="password"
name="password"
required
class="w-full pl-10 pr-4 py-3 rounded-xl bg-white border border-slate-300 focus:border-slate-900 focus:ring-1 focus:ring-slate-900 outline-none transition"
placeholder="Minimum 8 characters"
/>
</div>
</div>


<!-- CONFIRM PASSWORD -->
<div>
<label class="text-sm font-semibold text-slate-600">
Confirm Password
</label>

<div class="relative mt-2">
<i class="fa fa-lock absolute top-4 left-3 text-slate-400"></i>

<input
type="password"
name="confirmPassword"
required
class="w-full pl-10 pr-4 py-3 rounded-xl bg-white border border-slate-300 focus:border-slate-900 focus:ring-1 focus:ring-slate-900 outline-none transition"
/>
</div>
</div>


<!-- BUTTON -->
<button
class="w-full bg-slate-900 hover:bg-slate-800 text-white py-3 rounded-xl font-semibold text-lg transition">
Create Admin Account
</button>

</form>



<!-- LOGIN LINK -->
<p class="text-center text-slate-600 mt-6">
Already have an account?

<a href="/admin/login"
class="font-semibold text-slate-900 hover:underline ml-1">
Login here
</a>

</p>


<p class="text-center text-slate-400 mt-6 text-sm">
Restricted to authorized personnel only.
</p>

</div>

</body>
</html>

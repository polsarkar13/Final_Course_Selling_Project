<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>

<title>Admin Profile | AlgoMoney</title>
</head>

<%- include("../partials/toast") %>

<body class="bg-slate-100">

<div class="flex min-h-screen">

<!-- SIDEBAR -->
<aside class="w-72 bg-slate-900 text-white p-6">

<h1 class="text-2xl font-bold mb-10">
⚡ AlgoMoney Admin
</h1>

<nav class="space-y-3">

<a href="/admin/dashboard" class="block hover:bg-slate-800 px-4 py-3 rounded-lg transition">
<i class="fa fa-chart-line mr-2"></i> Dashboard
</a>

<a href="/admin/profile" class="block bg-slate-800 px-4 py-3 rounded-lg">
<i class="fa fa-user mr-2"></i> Profile
</a>

</nav>

</aside>

<!-- MAIN -->
<main class="flex-1 p-10">

<!-- HEADER -->
<div class="mb-10">
<h2 class="text-3xl font-bold text-slate-800">Admin Profile</h2>
<p class="text-slate-500 mt-1 text-sm">
Manage your personal information and security settings.
</p>
</div>

<div class="grid md:grid-cols-3 gap-8">

<!-- LEFT SIDE PROFILE CARD -->
<div class="bg-white rounded-2xl shadow-lg p-8">

<div class="flex flex-col items-center">

<div class="w-28 h-28 bg-gradient-to-br from-slate-900 to-slate-700 
text-white flex items-center justify-center 
rounded-full text-4xl font-bold shadow-md">
<%= admin.name.charAt(0).toUpperCase() %>
</div>

<h3 class="text-xl font-semibold mt-4"><%= admin.name %></h3>
<p class="text-slate-500 text-sm"><%= admin.email %></p>

<span class="mt-3 px-4 py-1 bg-green-100 text-green-600 text-xs rounded-full">
Super Administrator
</span>

</div>

<div class="mt-8 border-t pt-6 text-sm text-slate-600 space-y-2">
<p><strong>Account Status:</strong> Active</p>
<p><strong>Last Login:</strong> Today</p>
</div>

</div>

<!-- RIGHT SIDE -->
<div class="md:col-span-2 space-y-8">

<!-- UPDATE PROFILE -->
<div class="bg-white rounded-2xl shadow-lg p-8">

<div class="flex justify-between items-center mb-6">
<h3 class="text-xl font-semibold text-slate-800">
Personal Information
</h3>
<i class="fa fa-user text-slate-400"></i>
</div>

<form action="/admin/update-profile" method="POST" class="space-y-5">

<div>
<label class="block text-sm font-medium text-slate-600 mb-1">
Full Name
</label>
<input type="text" name="name" value="<%= admin.name %>"
class="w-full border border-slate-300 focus:ring-2 focus:ring-slate-900 focus:outline-none p-3 rounded-lg transition">
</div>

<div>
<label class="block text-sm font-medium text-slate-600 mb-1">
Email Address
</label>
<input type="email" name="email" value="<%= admin.email %>"
class="w-full border border-slate-300 focus:ring-2 focus:ring-slate-900 focus:outline-none p-3 rounded-lg transition">
</div>

<button type="submit"
class="bg-slate-900 hover:bg-slate-800 transition text-white px-6 py-2.5 rounded-lg shadow">
Save Changes
</button>

</form>

</div>

<!-- SECURITY SETTINGS -->
<div class="bg-white rounded-2xl shadow-lg p-8">

<div class="flex justify-between items-center mb-6">
<h3 class="text-xl font-semibold text-slate-800">
Security Settings
</h3>
<i class="fa fa-shield-halved text-slate-400"></i>
</div>

<form action="/admin/change-password" method="POST" class="space-y-5">

<div>
<label class="block text-sm font-medium text-slate-600 mb-1">
Current Password
</label>
<input type="password" name="currentPassword"
class="w-full border border-slate-300 focus:ring-2 focus:ring-red-500 focus:outline-none p-3 rounded-lg transition">
</div>

<div>
<label class="block text-sm font-medium text-slate-600 mb-1">
New Password
</label>
<input type="password" name="newPassword"
class="w-full border border-slate-300 focus:ring-2 focus:ring-red-500 focus:outline-none p-3 rounded-lg transition">
</div>

<div>
<label class="block text-sm font-medium text-slate-600 mb-1">
Confirm New Password
</label>
<input type="password" name="confirmPassword"
class="w-full border border-slate-300 focus:ring-2 focus:ring-red-500 focus:outline-none p-3 rounded-lg transition">
</div>

<button type="submit"
class="bg-red-600 hover:bg-red-700 transition text-white px-6 py-2.5 rounded-lg shadow">
Update Password
</button>

</form>

</div>

</div>

</div>

</main>

</div>

</body>
</html>
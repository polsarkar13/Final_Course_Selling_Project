<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>

<title>Payments Management</title>
</head>

<%- include("../partials/toast") %>

<body class="bg-slate-100">

<div class="flex min-h-screen">

<!-- SIDEBAR -->
<aside class="w-72 bg-slate-900 text-white p-6">

<h1 class="text-2xl font-bold mb-10">
⚡ AlgoMoney Admin
</h1>

<nav class="space-y-3">

<a href="/admin/dashboard" class="block hover:bg-slate-800 px-4 py-3 rounded-lg">
<i class="fa fa-chart-line mr-2"></i> Dashboard
</a>

<a href="/admin/users" class="block hover:bg-slate-800 px-4 py-3 rounded-lg">
<i class="fa fa-users mr-2"></i> Users
</a>

<a href="/admin/payments" class="block bg-slate-800 px-4 py-3 rounded-lg">
<i class="fa fa-credit-card mr-2"></i> Payments
</a>

</nav>
</aside>

<!-- MAIN -->
<main class="flex-1 p-10">

<!-- HEADER -->
<div class="flex justify-between items-center mb-10">
<h2 class="text-3xl font-bold">
Payments Management
</h2>
</div>

<!-- PAYMENTS TABLE -->
<div class="bg-white rounded-2xl shadow p-6 overflow-x-auto">

<table class="w-full text-left">

<thead>
<tr class="border-b text-gray-600">
<th class="p-3">User</th>
<th>Email</th>
<th>Phone</th>
<th>Amount</th>
<th>Status</th>
<th>Payment ID</th>
<th>Date</th>
</tr>
</thead>

<tbody>

<% payments.forEach(payment => { %>

<tr class="border-b hover:bg-slate-50">

<td class="p-3 font-semibold">
<%= payment.user ? payment.user.firstName : "Deleted User" %>
</td>

<td>
<%= payment.user ? payment.user.email : "-" %>
</td>

<td>
<%= payment.user ? payment.user.phone : "-" %>
</td>

<td class="font-bold text-indigo-600">
₹ <%= payment.amount %>
</td>

<td>
<span class="px-3 py-1 rounded-full text-sm
<%= payment.status === "paid"
  ? "bg-green-100 text-green-600"
  : payment.status === "failed"
  ? "bg-red-100 text-red-600"
  : "bg-yellow-100 text-yellow-600" %>">

<%= payment.status.toUpperCase() %>

</span>
</td>

<td class="text-sm text-gray-500">
<%= payment.razorpay_payment_id || "-" %>
</td>

<td class="text-sm text-gray-500">
<%= payment.createdAt.toDateString() %>
</td>

</tr>

<% }) %>

</tbody>

</table>

</div>

</main>

</div>

</body>
</html>
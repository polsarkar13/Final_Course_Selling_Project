<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Update Plan</title>

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>

</head>

<body class="bg-slate-100">

<div class="flex min-h-screen">

  <!-- SIDEBAR -->
  <aside class="w-72 bg-slate-900 text-white p-6">
    <h1 class="text-2xl font-bold mb-10">⚡ AlgoMoney Admin</h1>

    <nav class="space-y-3">
      <a href="/admin/dashboard" class="block hover:bg-slate-800 px-4 py-3 rounded-lg">
        <i class="fa fa-chart-line mr-2"></i> Dashboard
      </a>

      <a href="/admin/portfolios" class="block bg-slate-800 px-4 py-3 rounded-lg">
        <i class="fa fa-book mr-2"></i> Plans
      </a>
    </nav>
  </aside>

  <!-- MAIN CONTENT -->
  <main class="flex-1 p-10">

    <div class="max-w-3xl mx-auto">

      <h2 class="text-3xl font-bold mb-8">Update Plans</h2>

      <div class="bg-white rounded-2xl shadow-lg p-8">

        <form action="/admin/update-plan/<%= plan._id %>" method="POST" class="space-y-6">

          <!-- PRICE -->
          <div>
            <label class="block text-sm font-semibold mb-2"> Price (₹)</label>
            <input type="number" name="price" 
                   value="<%= plan.price %>" 
                   required
                   class="w-full border border-gray-300 rounded-xl p-3 focus:ring-2 focus:ring-primary outline-none">
          </div>
         

          <!-- ACTION BUTTONS -->
          <div class="flex justify-between items-center pt-4">

            <a href="/admin/plans"
               class="text-gray-500 hover:text-gray-700 font-medium">
               Cancel
            </a>

            <button type="submit"
              class="bg-slate-900 hover:bg-slate-800 text-white px-8 py-3 rounded-xl font-semibold transition shadow-md">
              <i class="fa fa-save mr-2"></i> Save Changes
            </button>

          </div>

        </form>

      </div>

    </div>

  </main>

</div>

</body>
</html>
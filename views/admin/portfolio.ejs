<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<script src="https://cdn.tailwindcss.com"></script>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet"/>

<title>Portfolio Management</title>
</head>

<%- include("../partials/toast") %>

<body class="bg-slate-100">

<div class="flex min-h-screen">

<!-- SIDEBAR -->
<aside class="w-72 bg-slate-900 text-white p-6">

<h1 class="text-2xl font-bold mb-10">
⚡ AlgoMoney Admin
</h1>

<nav class="space-y-3">

<a href="/admin/dashboard" class="block hover:bg-slate-800 px-4 py-3 rounded-lg">
<i class="fa fa-chart-line mr-2"></i> Dashboard
</a>

<a href="/admin/portfolio-management" class="block bg-slate-800 px-4 py-3 rounded-lg">
<i class="fa fa-briefcase mr-2"></i> Portfolio Management
</a>

</nav>
</aside>


<!-- MAIN -->
<main class="flex-1 p-10">

<!-- HEADER -->
<div class="flex justify-between items-center mb-10">

<h2 class="text-3xl font-bold">
Portfolio Management
</h2>

<button onclick="document.getElementById('createModal').classList.remove('hidden')"
class="bg-slate-900 text-white px-5 py-2 rounded-lg">
+ Create Portfolio
</button>

</div>


<!-- PORTFOLIO TABLE -->
<div class="bg-white rounded-2xl shadow p-6">

<table class="w-full text-left">

<thead>
<tr class="border-b">
<th class="p-3">Name</th>
<th>Risk</th>
<th>Annual Return</th>
<th>Status</th>
<th>Created</th>
<th>Action</th>
</tr>
</thead>

<tbody>

<% portfolios.forEach(portfolio => { %>

<tr class="border-b hover:bg-slate-50">

<td class="p-3 font-semibold">
<%= portfolio.name %>
</td>

<td>
<span class="px-3 py-1 rounded-full text-sm
<%= portfolio.riskLevel === 'Low' ? 'bg-green-100 text-green-600'
: portfolio.riskLevel === 'Moderate' ? 'bg-yellow-100 text-yellow-600'
: 'bg-red-100 text-red-600' %>">
<%= portfolio.riskLevel %>
</span>
</td>


<td>
  <%= portfolio.performanceSummary && portfolio.performanceSummary.averageAnnualROI
      ? portfolio.performanceSummary.averageAnnualROI
      : 0 %>%
</td>



<td>
<span class="px-3 py-1 rounded-full text-sm
<%= portfolio.isActive ? 'bg-green-100 text-green-600' : 'bg-red-100 text-red-600' %>">
<%= portfolio.isActive ? "Active" : "Inactive" %>
</span>
</td>

<td>
<%= portfolio.createdAt.toDateString() %>
</td>

<td class="space-x-3">

<a href="/admin/toggle-portfolio/<%= portfolio._id %>"
class="text-blue-600 font-semibold">
Toggle
</a>
<a href="/admin/update-portfolio/<%= portfolio._id %>"
class="text-blue-600 font-semibold">
Update
</a>
<form action="/admin/delete-portfolio/<%= portfolio._id %>?_method=DELETE" method="POST"
 onsubmit="return confirm('Are you sure?')">
<button type="submit" class="text-red-500 font-semibold">
    Delete
</button>
</form>

</td>

</tr>

<% }) %>

</tbody>
</table>

</div>

</main>

</div>


<!-- ================= CREATE PORTFOLIO MODAL ================= -->

<div id="createModal"
class="fixed inset-0 bg-black/50 hidden overflow-y-auto flex items-start justify-center py-10">

<div class="bg-white w-[800px] rounded-2xl p-8 shadow-2xl">

<h3 class="text-2xl font-bold mb-6">Create Portfolio</h3>

<form action="/admin/create-portfolio"
      method="POST"
      enctype="multipart/form-data">

<!-- BASIC INFO -->
<div class="space-y-4">
<h4 class="font-bold text-lg">Basic Information</h4>

<input type="text" name="name" placeholder="Portfolio Name"
class="w-full border p-3 rounded-lg" required>

<input type="text" name="slug" placeholder="Slug (conservative-growth)"
class="w-full border p-3 rounded-lg" required>

<textarea name="description" placeholder="Description"
class="w-full border p-3 rounded-lg" required></textarea>

<select name="riskLevel"
class="w-full border p-3 rounded-lg" required>
<option value="">Select Risk Level</option>
<option value="Low">Low</option>
<option value="Moderate">Moderate</option>
<option value="High">High</option>
</select>
</div>


<!-- PERFORMANCE SUMMARY -->
<div class="space-y-4">
<h4 class="font-bold text-lg">Performance Summary</h4>

<div class="grid grid-cols-2 gap-4">
<input type="number" step="0.01" name="averageAnnualROI" placeholder="Average Annual ROI %"
class="border p-3 rounded-lg">

<input type="number" step="0.01" name="maxRiskPerDay" placeholder="Max Risk Per Day %"
class="border p-3 rounded-lg">
</div>

<div class="grid grid-cols-2 gap-4">
<input type="number" name="capitalExpiryDays" placeholder="Capital For Expiry Days"
class="border p-3 rounded-lg">

<input type="number" name="capitalNonExpiryDays" placeholder="Capital For Non-Expiry Days"
class="border p-3 rounded-lg">
</div>

<input type="number" step="0.01" name="historicalMaxDD" placeholder="Historical Max Drawdown %"
class="w-full border p-3 rounded-lg">

<input type="number" step="0.01" name="price" placeholder="Price"
class="w-full border p-3 rounded-lg">
</div>

<!-- CHART LINKS -->
<div class="space-y-4">
<h4 class="font-bold text-lg">Upload Chart Images</h4>

<div>
<label class="block mb-2 font-medium">Equity Curve</label>
<input type="file"
       name="equityCurve"
       accept="image/*"
       class="w-full border p-3 rounded-lg bg-white">
</div>

<div>
<label class="block mb-2 font-medium">Monthly Report</label>
<input type="file"
       name="monthlyReport"
       accept="image/*"
       class="w-full border p-3 rounded-lg bg-white">
</div>

<div>
<label class="block mb-2 font-medium">Performance Stats</label>
<input type="file"
       name="performanceStats"
       accept="image/*"
       class="w-full border p-3 rounded-lg bg-white">
</div>

</div>

<!-- HIGHLIGHTS -->
<div class="space-y-4">
<h4 class="font-bold text-lg">Portfolio Highlights</h4>

<input type="text" name="highlight1" placeholder="Highlight 1"
class="w-full border p-3 rounded-lg">

<input type="text" name="highlight2" placeholder="Highlight 2"
class="w-full border p-3 rounded-lg">

<input type="text" name="highlight3" placeholder="Highlight 3"
class="w-full border p-3 rounded-lg">

<input type="text" name="highlight4" placeholder="Highlight 4"
class="w-full border p-3 rounded-lg">
</div>


<!-- ACTION BUTTONS -->
<div class="flex justify-end gap-4 mt-8">

<button type="button"
onclick="document.getElementById('createModal').classList.add('hidden')"
class="px-4 py-2 border rounded-lg">
Cancel
</button>

<button type="submit"
class="bg-slate-900 text-white px-6 py-2 rounded-lg">
Create Portfolio
</button>

</div>

</form>

</div>

</div>


</body>
</html>
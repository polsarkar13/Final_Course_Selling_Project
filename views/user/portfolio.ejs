<%- include("header") %>

<section class="text-center py-28 px-6 bg-gradient-to-b from-primary/20 via-slate-900 to-slate-950">

  <!-- Animated Shield Logo -->
  <div class="flex justify-center mb-8 animate-fadeUp delay-1">
    <div class="relative w-20 h-20 rounded-2xl
        bg-gradient-to-br from-indigo-500 via-blue-500 to-purple-600
        flex items-center justify-center
        shadow-lg shadow-indigo-500/30
        animate-gradient">

        <i class="fas fa-shield-alt text-white text-3xl"></i>

        <div class="absolute inset-0 rounded-2xl
            bg-gradient-to-br from-indigo-500 via-blue-500 to-purple-600
            blur-xl opacity-40 animate-pulse">
        </div>
    </div>
  </div>

  <h1 class="text-5xl md:text-6xl font-extrabold text-white mb-6 animate-fadeUp delay-2">
    Portfolio <span class="text-primary">Management</span>
  </h1>

  <p class="max-w-3xl mx-auto text-slate-400 text-lg animate-fadeUp delay-3">
    Let our expert fund managers grow your wealth with professionally managed
    portfolios designed for consistent returns and capital protection.
  </p>

</section>


<!-- PORTFOLIO CARDS -->
<section class="py-24 px-6 bg-slate-950">

<div class="max-w-7xl mx-auto">

    <!-- SECTION HEADER -->
<div class="text-center mb-16 animate-fadeUp delay-1">

  <h2 class="text-4xl md:text-5xl font-extrabold text-white mb-6">
    Choose Your <span class="text-primary">Portfolio</span>
  </h2>

  <p class="max-w-2xl mx-auto text-slate-400 text-lg leading-relaxed">
    Select from our expertly crafted portfolios designed for different 
    risk appetites and investment goals.
  </p>

  <!-- Decorative Line -->
  <div class="mt-8 flex justify-center">
    <div class="w-24 h-1 bg-gradient-to-r from-blue-500 to-indigo-600 rounded-full"></div>
  </div>

</div>

<div class="grid md:grid-cols-3 gap-10">

<% portfolios.forEach((portfolio, index) => { %>

<div 
  class="rounded-3xl p-10 text-center border transition duration-300 animate-fadeUp
  <%= portfolio.riskLevel === 'Low'
      ? 'bg-emerald-50 border-emerald-200'
      : portfolio.riskLevel === 'Moderate'
      ? 'bg-blue-50 border-blue-200 scale-105 shadow-xl'
      : 'bg-purple-50 border-purple-200' %>"
  
  style="animation-delay:<%= index * 0.25 %>s;"
>


  <!-- TITLE -->
  <h3 class="text-2xl font-bold text-slate-800 mb-4">
    <%= portfolio.name %>
  </h3>

  <!-- RISK BADGE -->
  <div class="mb-6">
    <span class="px-4 py-1 rounded-full text-sm font-semibold
    <%= portfolio.riskLevel === 'Low'
      ? 'bg-emerald-100 text-emerald-600'
      : portfolio.riskLevel === 'Moderate'
      ? 'bg-blue-100 text-blue-600'
      : 'bg-purple-100 text-purple-600' %>">
      <%= portfolio.riskLevel === 'Low' ? 'Low Risk'
        : portfolio.riskLevel === 'Moderate' ? 'Medium Risk'
        : 'High Risk' %>
    </span>
  </div>

  <!-- RETURNS -->
  <h4 class="text-4xl font-extrabold text-slate-900 mb-2">
    <%= portfolio.performanceSummary && portfolio.performanceSummary.averageAnnualROI
      ? portfolio.performanceSummary.averageAnnualROI
      : 0 %>%
  </h4>

  <p class="text-slate-500 mb-6">
    Expected Returns
  </p>

  <!-- DESCRIPTION -->

  <!-- MIN INVESTMENT -->
  <p class="font-semibold text-slate-800 mb-8">
    Min Investment: ₹<%= portfolio.performanceSummary && portfolio.performanceSummary.capitalExpiryDays
      ? portfolio.performanceSummary.capitalExpiryDays
      : 0 %> Lakhs
  </p>

  <!-- FEATURES -->
  <ul class="space-y-4 text-slate-600 mb-10 text-left">

    <% if(portfolio.highlights){ %>
      <% portfolio.highlights.forEach(item => { %>
        <li class="flex items-center gap-3">
          <i class="fas fa-check
          <%= portfolio.riskLevel === 'Low'
            ? 'text-emerald-500'
            : portfolio.riskLevel === 'Moderate'
            ? 'text-blue-500'
            : 'text-purple-500' %>">
          </i>
          <%= item %>
        </li>
      <% }) %>
    <% } %>

  </ul>

  <!-- CTA BUTTON -->
  <a href="/user/portfolio/<%= portfolio._id %>"
     class="block py-3 rounded-xl font-semibold text-white transition duration-300
     <%= portfolio.riskLevel === 'Low'
        ? 'bg-emerald-600 hover:bg-emerald-700'
        : portfolio.riskLevel === 'Moderate'
        ? 'bg-gradient-to-r from-blue-600 to-indigo-600 hover:opacity-90'
        : 'bg-gradient-to-r from-purple-600 to-pink-600 hover:opacity-90' %>">
     Choose This Portfolio
  </a>

</div>

<% }) %>

</div>
</div>

</section>


<!-- WHY CHOOSE SECTION -->
<section class="py-24 px-6 bg-slate-900">

<h2 class="text-center text-4xl font-bold text-white mb-6">
Why Choose Our PMS?
</h2>

<p class="text-center text-slate-400 mb-16 max-w-3xl mx-auto">
Experience professional portfolio management with proven strategies and disciplined execution.
</p>

<div class="grid md:grid-cols-4 gap-10 max-w-7xl mx-auto">

<div class="bg-slate-800 p-8 rounded-2xl text-center">
<i class="fas fa-shield-alt text-primary text-3xl mb-4"></i>
<h4 class="text-white font-semibold text-lg mb-2">Expert Management</h4>
<p class="text-slate-400 text-sm">
Professionally managed by experienced traders.
</p>
</div>

<div class="bg-slate-800 p-8 rounded-2xl text-center">
<i class="fas fa-chart-line text-primary text-3xl mb-4"></i>
<h4 class="text-white font-semibold text-lg mb-2">Data-Driven Decisions</h4>
<p class="text-slate-400 text-sm">
Backtested strategies with performance tracking.
</p>
</div>

<div class="bg-slate-800 p-8 rounded-2xl text-center">
<i class="fas fa-bullseye text-primary text-3xl mb-4"></i>
<h4 class="text-white font-semibold text-lg mb-2">Goal-Based Investing</h4>
<p class="text-slate-400 text-sm">
Portfolios aligned to your financial objectives.
</p>
</div>

<div class="bg-slate-800 p-8 rounded-2xl text-center">
<i class="fas fa-clock text-primary text-3xl mb-4"></i>
<h4 class="text-white font-semibold text-lg mb-2">24/7 Monitoring</h4>
<p class="text-slate-400 text-sm">
Continuous risk management and adjustments.
</p>
</div>

</div>

</section>

<%- include("footer") %>
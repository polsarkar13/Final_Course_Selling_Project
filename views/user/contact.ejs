<%- include("header") %>

<!-- HERO -->
<section class="bg-gradient-to-br from-slate-900 via-slate-950 to-indigo-950 py-24">

    <div class="max-w-6xl mx-auto text-center px-6">

        <div class="w-16 h-16 mx-auto mb-6 flex items-center justify-center bg-indigo-600 rounded-2xl shadow-lg shadow-indigo-600/30">
            <i class="fas fa-paper-plane text-white text-2xl"></i>
        </div>

        <h1 class="text-5xl font-bold text-white">
            Get in <span class="text-indigo-400">Touch</span>
        </h1>

        <p class="text-slate-300 mt-4 text-lg max-w-2xl mx-auto">
            Ready to start your algorithmic trading journey? Send us a message and we'll respond within 24 hours.
        </p>

    </div>

</section>



<!-- CONTACT CARDS -->
<section class="py-20 bg-slate-950">

    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-4 gap-8">

        <!-- Email -->
        <div class="bg-slate-900 border border-slate-800 p-8 rounded-2xl hover:border-indigo-500 transition text-center">
            <div class="w-14 h-14 mx-auto flex items-center justify-center bg-indigo-600 rounded-xl mb-4">
                <i class="fas fa-envelope text-white"></i>
            </div>

            <h3 class="font-semibold text-lg text-white">Email Us</h3>

            <p class="text-indigo-400 mt-2">
                algomoney.support@gmail.com
            </p>

            <p class="text-slate-400 text-sm mt-1">
                Send us an email anytime
            </p>
        </div>


        <!-- WhatsApp -->
        <div class="bg-slate-900 border border-slate-800 p-8 rounded-2xl hover:border-indigo-500 transition text-center">
            <div class="w-14 h-14 mx-auto flex items-center justify-center bg-indigo-600 rounded-xl mb-4">
                <i class="fas fa-phone text-white"></i>
            </div>

            <h3 class="font-semibold text-lg text-white">WhatsApp Us</h3>

            <p class="text-indigo-400 mt-2">
                +91 7908538916
            </p>

            <p class="text-slate-400 text-sm mt-1">
                Mon-Fri from 9am to 6pm
            </p>
        </div>


        <!-- Location -->
        <div class="bg-slate-900 border border-slate-800 p-8 rounded-2xl hover:border-indigo-500 transition text-center">
            <div class="w-14 h-14 mx-auto flex items-center justify-center bg-indigo-600 rounded-xl mb-4">
                <i class="fas fa-map-marker-alt text-white"></i>
            </div>

            <h3 class="font-semibold text-lg text-white">Visit Us</h3>

            <p class="text-indigo-400 mt-2">
                Kolkata, WestBengal
            </p>

            <p class="text-slate-400 text-sm mt-1">
                700030, India
            </p>
        </div>


        <!-- Hours -->
        <div class="bg-slate-900 border border-slate-800 p-8 rounded-2xl hover:border-indigo-500 transition text-center">
            <div class="w-14 h-14 mx-auto flex items-center justify-center bg-indigo-600 rounded-xl mb-4">
                <i class="fas fa-clock text-white"></i>
            </div>

            <h3 class="font-semibold text-lg text-white">Business Hours</h3>

            <p class="text-indigo-400 mt-2">
                9:00 AM – 6:00 PM
            </p>

            <p class="text-slate-400 text-sm mt-1">
                Monday to Friday
            </p>
        </div>

    </div>

</section>



<!-- FORM -->
<section class="py-24 bg-slate-950">

    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16">

        <!-- LEFT -->
        <div>

            <h2 class="text-3xl font-bold text-white">
                Send us a Message
            </h2>

            <p class="text-slate-400 mt-2 mb-8">
                Fill out the form below and we'll get back to you within 24 hours.
            </p>

            <form action="/contact" method="POST" class="space-y-5">

                <div class="grid md:grid-cols-2 gap-4">

                    <input 
                        name="name"
                        required
                        placeholder="Full Name *"
                        class="bg-slate-900 border border-slate-700 text-white rounded-lg px-4 py-3 w-full focus:border-indigo-500 focus:ring-2 focus:ring-indigo-600 outline-none"
                    />

                    <input 
                        name="email"
                        type="email"
                        required
                        placeholder="Email Address *"
                        class="bg-slate-900 border border-slate-700 text-white rounded-lg px-4 py-3 w-full focus:border-indigo-500 focus:ring-2 focus:ring-indigo-600 outline-none"
                    />

                </div>


                <div class="grid md:grid-cols-2 gap-4">

                    <input 
                        name="phone"
                        required
                        placeholder="Mobile No *"
                        class="bg-slate-900 border border-slate-700 text-white rounded-lg px-4 py-3 w-full focus:border-indigo-500 focus:ring-2 focus:ring-indigo-600 outline-none"
                    />

                    <select 
                        name="type"
                        class="bg-slate-900 border border-slate-700 text-white rounded-lg px-4 py-3 w-full focus:border-indigo-500 focus:ring-2 focus:ring-indigo-600 outline-none">
                        <option>General Inquiry</option>
                        <option>Pricing</option>
                        <option>Technical Support</option>
                        <option>Partnership</option>
                    </select>

                </div>


                <input 
                    name="subject"
                    required
                    placeholder="Subject *"
                    class="bg-slate-900 border border-slate-700 text-white rounded-lg px-4 py-3 w-full focus:border-indigo-500 focus:ring-2 focus:ring-indigo-600 outline-none"
                />

                <textarea 
                    name="message"
                    rows="5"
                    required
                    placeholder="Message *"
                    class="bg-slate-900 border border-slate-700 text-white rounded-lg px-4 py-3 w-full focus:border-indigo-500 focus:ring-2 focus:ring-indigo-600 outline-none"
                ></textarea>


                <button 
                    class="w-full bg-gradient-to-r from-indigo-600 to-blue-600 hover:scale-[1.02] text-white px-8 py-3 rounded-lg font-semibold shadow-lg shadow-indigo-600/30 transition">
                    Send Message
                </button>

            </form>

        </div>



        <!-- RIGHT PANEL -->
        <div class="bg-slate-900 border border-slate-800 p-10 rounded-3xl">

            <h3 class="text-2xl font-bold text-white mb-6">
                Why Choose AlgoMoney?
            </h3>

            <ul class="space-y-4 text-slate-300">

                <li class="flex items-center gap-3">
                    <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                    95% success rate algorithms
                </li>

                <li class="flex items-center gap-3">
                    <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                    Real-time risk management
                </li>

                <li class="flex items-center gap-3">
                    <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                    Custom trading strategies
                </li>

                <li class="flex items-center gap-3">
                    <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                    24/7 market monitoring
                </li>

            </ul>

        </div>

    </div>

</section>

<%- include("footer") %>

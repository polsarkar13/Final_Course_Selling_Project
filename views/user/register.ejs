<%- include("header") %>

    <div class="min-h-screen flex bg-slate-900">

        <!-- LEFT SIDE -->
        <div
            class="hidden lg:flex w-1/2 bg-gradient-to-br from-indigo-900 via-slate-900 to-slate-950 items-center justify-center px-16">
            <div class="max-w-lg">

                <div class="mb-6">
                    <div class="w-14 h-14 flex items-center justify-center bg-indigo-600 rounded-xl shadow-lg">
                        <i class="fas fa-bolt text-white text-2xl"></i>
                    </div>
                </div>

                <h1 class="text-5xl font-bold text-white leading-tight mb-6">
                    Start Your Journey with <br> AlgoMoney
                </h1>

                <p class="text-lg text-gray-400">
                    Join thousands of traders accelerating their growth with our powerful algorithmic platform.
                </p>

            </div>
        </div>


        <!-- RIGHT SIDE (REGISTER CARD) -->
        <div class="flex w-full lg:w-1/2 items-center justify-center bg-slate-900 py-10 px-6">

            <div class="bg-slate-800 border border-slate-700 w-full max-w-md p-8 rounded-2xl shadow-2xl">

                <h2 class="text-3xl font-bold text-white mb-2">
                    Create Your Account
                </h2>

                <p class="text-gray-400 mb-6">
                    Get started in under 30 seconds
                </p>

                <form action="/user/signup" method="POST" class="space-y-4">

                    <!-- Name -->
                    <div class="flex gap-4">
                        <input type="text" name="firstName" placeholder="First Name" required
                            class="w-1/2 bg-slate-900 border border-slate-600 text-white placeholder-gray-400 px-4 py-3 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" />

                        <input type="text" name="lastName" placeholder="Last Name" required
                            class="w-1/2 bg-slate-900 border border-slate-600 text-white placeholder-gray-400 px-4 py-3 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" />
                    </div>

                    <!-- Email -->
                    <input type="email" name="email" placeholder="Email Address" required
                        class="w-full bg-slate-900 border border-slate-600 text-white placeholder-gray-400 px-4 py-3 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" />
                    <!-- Phone Number -->
                    <input type="tel" name="phone" placeholder="Enter your phone number" required autocomplete="tel"
                        class="w-full bg-slate-900 border border-slate-600 text-white placeholder-gray-400 px-4 py-3 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition" />

                    <!-- Password -->
                    <input type="password" name="password" placeholder="Create a strong password" required
                        class="w-full bg-slate-900 border border-slate-600 text-white placeholder-gray-400 px-4 py-3 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" />

                    <!-- Confirm Password -->
                    <input type="password" name="confirmPassword" placeholder="Confirm your password" required
                        class="w-full bg-slate-900 border border-slate-600 text-white placeholder-gray-400 px-4 py-3 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none" />

                    <!-- Terms -->
                    <div class="flex items-start gap-2 text-sm text-gray-400">
                        <input type="checkbox" required class="accent-indigo-600 mt-1">

                        <span>
                            I agree to the
                            <a href="#" class="text-indigo-400 font-medium hover:text-indigo-300">Terms of Service</a>
                            and
                            <a href="#" class="text-indigo-400 font-medium hover:text-indigo-300">Privacy Policy</a>
                        </span>
                    </div>

                    <!-- Button -->
                    <button type="submit"
                        class="w-full bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-blue-600 hover:to-indigo-600 text-white py-3 rounded-lg font-semibold shadow-lg transition">
                        Create Account
                    </button>

                    <!-- Login redirect -->
                    <p class="text-center text-gray-400 text-sm mt-4">
                        Already have an account?
                        <a href="/user/login" class="text-indigo-400 font-semibold hover:text-indigo-300">
                            Login
                        </a>
                    </p>

                </form>

            </div>
        </div>

    </div>

    <%- include("footer") %>
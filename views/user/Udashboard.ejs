<!-- FINAL CTA -->
<section class="py-20 text-center bg-primary">

<h3 class="text-3xl font-bold text-white mb-4">
Start Trading Like a Professional
</h3>

<p class="text-indigo-100 mb-8">
Build discipline before chasing profits.
</p>

<a href="/user/register"
class="bg-white text-primary px-10 py-4 rounded-xl font-semibold">
Join AlgoMoney
</a>

</section>


<%- include("footer") %>

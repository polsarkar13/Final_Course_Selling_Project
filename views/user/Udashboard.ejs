<h3 class="text-xl font-semibold mb-4">Starter</h3>

<p class="text-4xl font-bold text-white mb-6">
₹<%= plans.starter ? plans.starter.price : "0" %>
<span class="text-lg text-slate-400"> /mo</span>
</p>


</ul>

<a href="/user/eliteplan/<%= plans.elite._id %>"
class="block text-center bg-primary py-3 rounded-xl hover:bg-indigo-700">
Join Elite
</a>
</div>

</div>
</section>



<!-- TESTIMONIALS -->
<section class="py-24 bg-slate-950">

<h2 class="text-center text-4xl font-bold text-white mb-16">
What Traders Say
</h2>

<div class="grid md:grid-cols-3 gap-10 max-w-6xl mx-auto px-6">

<div class="bg-slate-900 p-8 rounded-2xl">

<%- include("header") %>


<!-- HERO -->
<section class="text-center py-32 px-6 relative overflow-hidden">

  <!-- Background trading image (Unsplash, free) -->
  <div style="
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=1600&q=80&auto=format&fit=crop');
    background-size: cover;
    background-position: center;
    opacity: 0.15;
    z-index: 0;
  "></div>

  <!-- Gradient overlay: top-to-bottom fade matching your site's dark base -->
  <div style="
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(99, 102, 241, 0.25) 0%,
      rgba(15, 23, 42, 0.7) 55%,
      #0f172a 100%
    );
    z-index: 1;
  "></div>

  <!-- All hero content sits above both layers -->
  <div class="relative" style="z-index: 2;">

    <h1 class="text-5xl md:text-6xl font-extrabold text-white leading-tight mb-6">
      Build Consistent Trading Income  
      <span class="text-primary">Without Guesswork</span>
    </h1>

    <p class="max-w-2xl mx-auto text-slate-300 text-lg mb-10">
      Backtested strategies, structured education, and professional risk management  
      designed for serious traders — not gamblers.
    </p>

    <div class="flex justify-center gap-4 flex-wrap">

      <a href="/user/register"
        class="bg-primary hover:bg-indigo-700 px-10 py-4 rounded-xl text-lg font-semibold shadow-2xl shadow-primary/30">
        View Plans
      </a>

      <a href="/user/about"
        class="border border-slate-600 px-10 py-4 rounded-xl hover:border-white">
        Learn More
      </a>

    </div>

    <!-- TRUST BAR -->
    <p class="mt-12 text-slate-400">
      Trusted by <span class="text-white font-semibold">100+ traders</span> across India •  
      Rated <span class="text-white font-semibold">4.9/5</span>
    </p>

  </div><!-- /relative content wrapper -->

</section>



<!-- WHAT WE OFFER -->
<section class="py-24 px-10 max-w-7xl mx-auto">

<h2 class="text-center text-4xl font-bold text-white mb-16">
Everything You Need To Trade Professionally
</h2>

<div class="grid md:grid-cols-3 gap-10">

<!-- CARD 1 -->
<div class="bg-slate-900 p-10 rounded-3xl border border-slate-800 hover:border-indigo-500 transition group">

    <div class="w-14 h-14 flex items-center justify-center bg-indigo-600/20 rounded-xl mb-6">
        <i class="fas fa-briefcase text-indigo-400 text-2xl"></i>
    </div>

    <h3 class="text-xl font-semibold text-white mb-3">
        Portfolio Management
    </h3>

    <p class="text-slate-400 mb-8">
        Smart, expert-managed portfolios designed to grow your wealth with minimal risk.
    </p>

    <a href="/user/portfolio"
       class="inline-flex items-center gap-2 bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-indigo-600 hover:to-blue-600 text-white px-6 py-3 rounded-xl font-semibold shadow-lg transition duration-300 group-hover:scale-105">
        Get Started 
        <i class="fas fa-arrow-right text-sm"></i>
    </a>

</div>



<!-- CARD 2 -->
<div class="bg-slate-900 p-10 rounded-3xl border border-indigo-500 shadow-xl group">

    <div class="w-14 h-14 flex items-center justify-center bg-emerald-600/20 rounded-xl mb-6">
        <i class="fas fa-graduation-cap text-emerald-400 text-2xl"></i>
    </div>

    <h3 class="text-xl font-semibold text-white mb-3">
        Courses
    </h3>

    <p class="text-slate-400 mb-8">
        Learn trading and investing with easy, practical courses for all skill levels.
    </p>

    <a href="/user/courses"
       class="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-3 rounded-xl font-semibold shadow-lg transition duration-300 group-hover:scale-105">
        Start Learning 
        <i class="fas fa-arrow-right text-sm"></i>
    </a>

</div>



<!-- CARD 3 -->
<div class="bg-slate-900 p-10 rounded-3xl border border-slate-800 hover:border-pink-500 transition group">

    <div class="w-14 h-14 flex items-center justify-center bg-pink-600/20 rounded-xl mb-6">
        <i class="fas fa-robot text-pink-400 text-2xl"></i>
    </div>

    <h3 class="text-xl font-semibold text-white mb-3">
        Subscription-Based Algo System
    </h3>

    <p class="text-slate-400 mb-8">
        Automate your trades with powerful, ready-to-use algorithmic strategies.
    </p>

    <a href="/user/algo"
       class="inline-flex items-center gap-2 bg-gradient-to-r from-pink-600 to-purple-600 hover:from-purple-600 hover:to-pink-600 text-white px-6 py-3 rounded-xl font-semibold shadow-lg transition duration-300 group-hover:scale-105">
        Explore Systems 
        <i class="fas fa-arrow-right text-sm"></i>
    </a>

</div>

</div>
</section>



<!-- AUTHORITY -->
<section class="py-24 px-10 bg-slate-950 text-center">

<h2 class="text-4xl font-bold text-white mb-6">
Built By Traders — Not Influencers
</h2>

<p class="max-w-3xl mx-auto text-slate-400 text-lg">
AlgoMoney was created with one mission: eliminate emotional trading.
Our philosophy is simple — risk first, discipline always, profits later.
No hype. No shortcuts. Just structured systems.
</p>

</section>




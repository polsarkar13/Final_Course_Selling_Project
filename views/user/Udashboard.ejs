<!-- FAQ -->
<section class="py-24 px-6 max-w-4xl mx-auto">

<h2 class="text-center text-4xl font-bold text-white mb-12">
Frequently Asked Questions
</h2>

<div class="space-y-6 text-slate-300">

<div>
<h4 class="font-semibold text-white">Is this suitable for beginners?</h4>

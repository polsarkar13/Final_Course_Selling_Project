<%- include("header") %>

<section class="min-h-screen bg-gradient-to-b from-slate-900 via-slate-950 to-black py-20 px-6">
  <div class="max-w-7xl mx-auto">

    <!-- Page Title -->
    <div class="mb-12">
      <h1 class="text-4xl font-bold text-white mb-2">My Purchases</h1>
      <p class="text-slate-400">All your purchased courses, portfolios & plans.</p>
    </div>

    <!-- ✅ COURSES SECTION -->
    <% if (courses.length > 0) { %>
    <div class="mb-14">

      <h2 class="text-2xl font-semibold text-white mb-6 flex items-center gap-3">
        <i class="fa-solid fa-graduation-cap text-indigo-400"></i>
        Courses
      </h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% courses.forEach(item => { %>
        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 hover:border-indigo-500 transition">

          <div class="w-12 h-12 bg-indigo-500/10 border border-indigo-500/20 rounded-xl flex items-center justify-center mb-4">
            <i class="fa-solid fa-book text-indigo-400"></i>
          </div>

          <h3 class="text-lg font-semibold text-white mb-2">
            <%= item.title %>
          </h3>

          <p class="text-slate-400 text-sm mb-4">
            Full Course Access
          </p>

          <div class="flex items-center justify-between">
            <span class="text-indigo-400 font-semibold">₹ <%= item.price %></span>
            <span class="text-xs bg-green-500/10 text-green-400 border border-green-500/20 px-3 py-1 rounded-full">
              ✅ Purchased
            </span>
          </div>

        </div>
        <% }) %>
      </div>

    </div>
    <% } %>

    <!-- ✅ PORTFOLIOS SECTION -->
    <% if (portfolios.length > 0) { %>
    <div class="mb-14">

      <h2 class="text-2xl font-semibold text-white mb-6 flex items-center gap-3">
        <i class="fa-solid fa-briefcase text-purple-400"></i>
        Portfolios
      </h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% portfolios.forEach(item => { %>
        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 hover:border-purple-500 transition">

          <div class="w-12 h-12 bg-purple-500/10 border border-purple-500/20 rounded-xl flex items-center justify-center mb-4">
            <i class="fa-solid fa-chart-line text-purple-400"></i>
          </div>

          <h3 class="text-lg font-semibold text-white mb-2">
            <%= item.title %>
          </h3>

          <p class="text-slate-400 text-sm mb-4">
            Portfolio Access
          </p>

          <div class="flex items-center justify-between">
            <span class="text-purple-400 font-semibold">₹ <%= item.price %></span>
            <span class="text-xs bg-green-500/10 text-green-400 border border-green-500/20 px-3 py-1 rounded-full">
              ✅ Purchased
            </span>
          </div>

        </div>
        <% }) %>
      </div>

    </div>
    <% } %>

    <!-- ✅ PLANS SECTION -->
    <% if (plans.length > 0) { %>
    <div class="mb-14">

      <h2 class="text-2xl font-semibold text-white mb-6 flex items-center gap-3">
        <i class="fa-solid fa-crown text-yellow-400"></i>
        Plans
      </h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <% plans.forEach(item => { %>
        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 hover:border-yellow-500 transition">

          <div class="w-12 h-12 bg-yellow-500/10 border border-yellow-500/20 rounded-xl flex items-center justify-center mb-4">
            <i class="fa-solid fa-star text-yellow-400"></i>
          </div>

          <h3 class="text-lg font-semibold text-white mb-2">
            <%= item.title %>
          </h3>

          <p class="text-slate-400 text-sm mb-4">
            Premium Plan Access
          </p>

          <div class="flex items-center justify-between">
            <span class="text-yellow-400 font-semibold">₹ <%= item.price %></span>
            <span class="text-xs bg-green-500/10 text-green-400 border border-green-500/20 px-3 py-1 rounded-full">
              ✅ Active
            </span>
          </div>

        </div>
        <% }) %>
      </div>

    </div>
    <% } %>

    <!-- EMPTY STATE -->
    <% if (courses.length === 0 && portfolios.length === 0 && plans.length === 0) { %>
    <div class="text-center py-32">

      <div class="text-6xl mb-6 text-slate-700">
        <i class="fa-solid fa-box-open"></i>
      </div>

      <h2 class="text-2xl text-white font-semibold mb-3">
        No purchases yet
      </h2>

      <p class="text-slate-400 mb-6">
        Browse our premium plans & courses to get started.
      </p>

      <a href="/user/dashboard"
         class="inline-block bg-indigo-600 hover:bg-indigo-500 text-white px-6 py-3 rounded-xl transition">
         Explore Products
      </a>

    </div>
    <% } %>

  </div>
</section>

<%- include("footer") %>

<!-- ### What it shows:
```
📚 Courses section    → indigo theme
💼 Portfolios section → purple theme  
👑 Plans section      → yellow theme
✅ Purchased badge on each card
📦 Empty state if nothing bought -->
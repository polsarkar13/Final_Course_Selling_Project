<%- include("header") %>

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-900 via-indigo-950 to-slate-900">

    <div class="bg-slate-800 border border-slate-700 w-full max-w-md p-10 rounded-3xl shadow-2xl">

        <!-- Logo -->
        <div class="flex justify-center mb-6">
            <div class="w-14 h-14 flex items-center justify-center bg-indigo-600 rounded-xl shadow-lg">
                <i class="fas fa-bolt text-white text-2xl"></i>
            </div>
        </div>

        <!-- Heading -->
        <h2 class="text-3xl font-bold text-center text-white">
            Welcome Back
        </h2>

        <p class="text-center text-gray-400 mt-2 mb-8">
            Sign in to your AlgoMoney account
        </p>

        <!-- FORM -->
        <form action="/user/login" method="POST" class="space-y-5">

            <!-- Email -->
            <div>
                <label class="text-sm text-gray-300">Email Address</label>
                <div class="relative mt-1">
                    <i class="fa-regular fa-envelope absolute left-3 top-4 text-gray-400"></i>
                    <input 
                        type="email"
                        name="email"
                        placeholder="Enter your email"
                        required
                        class="w-full bg-slate-900 border border-slate-600 text-white placeholder-gray-400 pl-10 pr-4 py-3 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none"
                    />
                </div>
            </div>

            <!-- Password -->
            <div>
                <label class="text-sm text-gray-300">Password</label>
                <div class="relative mt-1">
                    <i class="fa-solid fa-lock absolute left-3 top-4 text-gray-400"></i>
                    <input 
                        type="password"
                        name="password"
                        placeholder="Enter your password"
                        required
                        class="w-full bg-slate-900 border border-slate-600 text-white placeholder-gray-400 pl-10 pr-10 py-3 rounded-lg focus:ring-2 focus:ring-indigo-500 outline-none"
                    />
                    <i class="fa-regular fa-eye absolute right-3 top-4 text-gray-400 cursor-pointer hover:text-white"></i>
                </div>
            </div>

            <!-- Remember + Forgot -->
            <div class="flex items-center justify-between text-sm">
                
                <a href="/user/forgot-password" class="text-indigo-400 font-medium hover:text-indigo-300">
                    Forgot password?
                </a>
            </div>

            <!-- Button -->
            <button 
                type="submit"
                class="w-full bg-gradient-to-r from-indigo-600 to-blue-600 hover:from-blue-600 hover:to-indigo-600 text-white py-3 rounded-lg font-semibold shadow-lg transition duration-300"
            >
                Sign In
            </button>

        </form>

        <!-- Divider -->
        <div class="my-6 border-t border-slate-700"></div>

        <!-- Signup -->
        <p class="text-center text-gray-400">
            Don't have an account?
            <a href="/user/register" class="text-indigo-400 font-semibold hover:text-indigo-300">
                Sign up now
            </a>
        </p>

    </div>
</div>

<%- include("footer") %>

<%- include("header") %>

<section class="min-h-screen bg-gradient-to-b from-slate-900 via-slate-950 to-black py-20 px-6">

  <div class="max-w-7xl mx-auto">

    <!-- Page Title -->
    <div class="mb-12">
      <h1 class="text-4xl font-bold text-white mb-2">Your Cart</h1>
      <p class="text-slate-400">Review your selected plans & courses before checkout.</p>
    </div>

    <% if (cart && cart.items.length > 0) { %>

    <div class="grid lg:grid-cols-3 gap-10">

      <!-- LEFT SIDE - CART ITEMS -->
      <div class="lg:col-span-2 space-y-6">

        <% cart.items.forEach(item => { %>

        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 flex justify-between items-center hover:border-indigo-500 transition">

          <!-- Item Info -->
          <div>
            <h2 class="text-xl font-semibold text-white">
              <%= item.title %>
            </h2>
            <p class="text-slate-400 text-sm mt-1">
              Premium Access
            </p>
          </div>

          <!-- Price & Actions -->
          <div class="text-right">

            <p class="text-lg font-bold text-indigo-500 mb-3">
              ₹ <%= item.price %>
            </p>

            <div class="flex items-center gap-3 justify-end">

              <!-- Remove Button -->
              <a href="/user/cart/remove/<%= item._id %>"
                 class="text-sm text-red-500 hover:text-red-400 transition">
                 Remove
              </a>

            </div>

          </div>

        </div>

        <% }) %>

      </div>

      <!-- RIGHT SIDE - SUMMARY -->
      <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8 h-fit sticky top-24">

        <h3 class="text-2xl font-semibold text-white mb-6">
          Order Summary
        </h3>

        <div class="space-y-4 text-slate-400">

          <div class="flex justify-between">
            <span>Subtotal</span>
            <span class="text-white font-medium">
              ₹ <%= totalAmount %>
            </span>
          </div>

          <div class="flex justify-between">
            <span>Tax</span>
            <span class="text-white font-medium">
              ₹ 0
            </span>
          </div>

          <hr class="border-slate-800">

          <div class="flex justify-between text-lg">
            <span class="text-white font-semibold">Total</span>
            <span class="text-indigo-500 font-bold">
              ₹ <%= totalAmount %>
            </span>
          </div>

        </div>

        <!-- Checkout Button -->
        <button id="payBtn"
          class="mt-8 block w-full text-center bg-indigo-600 hover:bg-indigo-500
                 text-white py-3 rounded-xl font-semibold transition shadow-md hover:shadow-lg">
          Proceed to Payment
        </button>

      </div>

    </div>

    <% } else { %>

    <!-- EMPTY CART -->
    <div class="text-center py-32">

      <div class="text-6xl mb-6 text-slate-700">
        <i class="fa-solid fa-cart-shopping"></i>
      </div>

      <h2 class="text-2xl text-white font-semibold mb-3">
        Your cart is empty
      </h2>

      <p class="text-slate-400 mb-6">
        Browse our premium plans & courses to start building consistent income.
      </p>

      <a href="/user/dashboard"
         class="inline-block bg-indigo-600 hover:bg-indigo-500
                text-white px-6 py-3 rounded-xl transition">
         Explore Products
      </a>

    </div>

    <% } %>

  </div>

</section>

<!-- ✅ Razorpay SDK -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
  document.getElementById("payBtn").addEventListener("click", async () => {

    try {

      // Step 1: Create order on backend
      const res = await fetch("/user/create-order", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          amount: <%= totalAmount %>,
          cartId: "<%= cart._id %>"
        })
      });

      const data = await res.json();

      if (!data.success) {
        alert("Failed to create order. Please try again.");
        return;
      }

      // Step 2: Open Razorpay with all payment methods
      const options = {
        key: "<%= process.env.RAZORPAY_KEY_ID %>",
        amount: data.amount,
        currency: data.currency,
        name: "Algo Money",
        description: "Course Purchase",
        order_id: data.orderId,

        // ✅ All payment methods
        config: {
          display: {
            blocks: {
              utib: {
                name: "Pay via UPI",
                instruments: [{ method: "upi" }]
              },
              other: {
                name: "Other Methods",
                instruments: [
                  { method: "card" },
                  { method: "netbanking" },
                  { method: "wallet" },
                  { method: "emi" },
                  { method: "paylater" }
                ]
              }
            },
            sequence: ["block.utib", "block.other"],
            preferences: { show_default_blocks: true }
          }
        },

        // Step 3: On payment success
        handler: async function (response) {

          const verifyRes = await fetch("/user/verify-payment", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              razorpay_order_id:   response.razorpay_order_id,
              razorpay_payment_id: response.razorpay_payment_id,
              razorpay_signature:  response.razorpay_signature
            })
          });

          const verifyData = await verifyRes.json();

          if (verifyData.success) {
            window.location.href = "/user/payment-success";
          } else {
            alert("Payment verification failed. Contact support.");
          }
        },

        prefill: {
          name:  "<%= user.name %>",
          email: "<%= user.email %>"
        },

        notes: {
          cart_id: "<%= cart._id %>"
        },

        theme: { color: "#6366f1" }
      };

      const rzp = new Razorpay(options);
      rzp.open();

      rzp.on("payment.failed", function (response) {
        alert("Payment failed: " + response.error.description);
      });

    } catch (err) {
      console.error("Payment error:", err);
      alert("Something went wrong. Please try again.");
    }

  });
</script>

<%- include("footer") %>
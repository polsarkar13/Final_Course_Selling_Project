<%- include("header") %>

<!-- HERO -->
<section class="py-20 px-6 text-center bg-gradient-to-b from-primary/20 via-slate-900 to-slate-950">

    <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4">
        Starter Plan Portfolios
    </h1>

    <p class="text-slate-400 max-w-2xl mx-auto">
        Low-risk structured portfolios designed for disciplined capital growth.
    </p>

</section>



<!-- PORTFOLIO LIST -->
<section class="py-16 px-6 max-w-7xl mx-auto">

    <% if (portfolios && portfolios.length > 0) { %>

        <div class="grid md:grid-cols-2 gap-12">

            <% portfolios.forEach(function(portfolio){ %>

                <div class="bg-slate-900 rounded-3xl border border-slate-800 shadow-xl overflow-hidden">

                    <!-- Header -->
                    <div class="p-8 border-b border-slate-800">

                        <div class="flex justify-between items-center mb-4">
                            <h2 class="text-2xl font-bold text-white">
                                <%= portfolio.name %>
                            </h2>

                            <span class="px-3 py-1 text-sm rounded-full 
                                <%= portfolio.riskLevel === 'Low' ? 'bg-emerald-600/20 text-emerald-400' :
                                    portfolio.riskLevel === 'Medium' ? 'bg-yellow-600/20 text-yellow-400' :
                                    'bg-red-600/20 text-red-400' %>">
                                <%= portfolio.riskLevel %> Risk
                            </span>
                        </div>

                        <p class="text-slate-400 mb-6">
                            <%= portfolio.description %>
                        </p>

                        <div class="text-3xl font-bold text-primary">
                            ₹<%= portfolio.price %> 
                            <span class="text-lg text-slate-400">/month</span>
                        </div>

                    </div>



                    <!-- PERFORMANCE SUMMARY -->
                    <div class="p-8 border-b border-slate-800">

                        <h3 class="text-lg font-semibold text-white mb-6">
                            Performance Overview
                        </h3>

                        <div class="grid grid-cols-2 gap-6 text-slate-300">

                            <div>
                                <p class="text-slate-500 text-sm">Avg Annual ROI</p>
                                <p class="text-xl font-semibold text-emerald-400">
                                    <%= portfolio.performanceSummary.averageAnnualROI %>%
                                </p>
                            </div>

                            <div>
                                <p class="text-slate-500 text-sm">Max Risk / Day</p>
                                <p class="text-xl font-semibold">
                                    <%= portfolio.performanceSummary.maxRiskPerDay %>%
                                </p>
                            </div>

                            <div>
                                <p class="text-slate-500 text-sm">Capital Expiry</p>
                                <p class="text-xl font-semibold">
                                    <%= portfolio.performanceSummary.capitalExpiryDays %> Days
                                </p>
                            </div>

                            <div>
                                <p class="text-slate-500 text-sm">Historical Max DD</p>
                                <p class="text-xl font-semibold text-red-400">
                                    <%= portfolio.performanceSummary.historicalMaxDD %>%
                                </p>
                            </div>

                        </div>

                    </div>



                    <!-- CHARTS -->
                    <div class="p-8 border-b border-slate-800">

                        <h3 class="text-lg font-semibold text-white mb-6">
                            Performance Charts
                        </h3>

                        <div class="space-y-6">

                            <img src="<%= portfolio.charts.equityCurve %>" 
                                 class="rounded-xl border border-slate-800">

                            <img src="<%= portfolio.charts.monthlyReport %>" 
                                 class="rounded-xl border border-slate-800">

                            <img src="<%= portfolio.charts.performanceStats %>" 
                                 class="rounded-xl border border-slate-800">

                        </div>

                    </div>



                    <!-- HIGHLIGHTS -->
                    <div class="p-8">

                        <h3 class="text-lg font-semibold text-white mb-6">
                            Key Highlights
                        </h3>

                        <ul class="space-y-3 text-slate-400">

                            <% portfolio.highlights.forEach(function(point){ %>
                                <li>✔ <%= point %></li>
                            <% }) %>

                        </ul>

                        <a href="/user/checkout/<%= portfolio._id %>"
                           class="block text-center mt-8 bg-primary py-3 rounded-xl hover:bg-indigo-700 font-semibold">
                            Subscribe Now
                        </a>

                    </div>

                </div>

            <% }) %>

        </div>

    <% } else { %>

        <div class="text-center text-slate-500">
            No Starter portfolios available right now.
        </div>

    <% } %>

</section>



<!-- DISCLAIMER -->
<section class="py-16 text-center bg-slate-950">

    <p class="text-slate-500 max-w-3xl mx-auto text-sm">
        All performance data is historical and for educational purposes only. 
        Returns are not guaranteed. Risk management discipline is mandatory.
    </p>

</section>


<%- include("footer") %>
<%- include("header") %>

<section class="min-h-screen bg-gradient-to-b from-slate-900 via-slate-950 to-black flex items-center justify-center px-6">

  <div class="text-center max-w-lg mx-auto">

    <!-- Success Icon -->
    <div class="w-24 h-24 bg-green-500/10 border border-green-500/30 rounded-full flex items-center justify-center mx-auto mb-8">
      <i class="fa-solid fa-check text-4xl text-green-400"></i>
    </div>

    <!-- Title -->
    <h1 class="text-4xl font-bold text-white mb-4">
      Payment Successful!
    </h1>

    <p class="text-slate-400 text-lg mb-8">
      Your purchase is confirmed. You can now access your courses from the dashboard.
    </p>

    <!-- Order Info -->
    <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 text-left mb-8 space-y-3">

      <div class="flex justify-between">
        <span class="text-slate-400">Status</span>
        <span class="text-green-400 font-semibold">✅ Paid</span>
      </div>

      <hr class="border-slate-800">

      <div class="flex justify-between">
        <span class="text-slate-400">Amount Paid</span>
        <span class="text-white font-semibold">₹ <%= amount || "—" %></span>
      </div>

      <hr class="border-slate-800">

      <div class="flex justify-between">
        <span class="text-slate-400">Payment ID</span>
        <span class="text-white font-mono text-sm"><%= paymentId || "—" %></span>
      </div>

    </div>

    <!-- Actions -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center">

      <a href="/user/dashboard"
         class="bg-indigo-600 hover:bg-indigo-500 text-white px-8 py-3 rounded-xl font-semibold transition">
         Go to Dashboard
      </a>

      <a href="/user/my-courses"
         class="bg-slate-800 hover:bg-slate-700 text-white px-8 py-3 rounded-xl font-semibold transition">
         My Courses
      </a>

    </div>

  </div>

</section>

<%- include("footer") %>